# Copy this file to .env and fill in your secrets. Do NOT commit .env to git.

# Server settings
PORT=4000
CORS_ORIGIN=http://localhost:5175

# API keys (keep these secret)
# SCHOOL_SEARCH_API_KEY=your_school_search_api_key_here
# STRATUM_AGENT_API_KEY=your_stratum_agent_api_key_here
# If you want to use Hugging Face Inference API, set STRATUM_AGENT_API_KEY to your HF token (starts with hf_)
# and optionally set STRATUM_AGENT_MODEL (e.g. 'gpt2' or 'declare-lab/flan-alpaca-large').
# STRATUM_AGENT_MODEL=gpt2

# Optional College Scorecard key (if you prefer Scorecard over Google Places)
# SCORECARD_API_KEY=your_data_gov_key_here
